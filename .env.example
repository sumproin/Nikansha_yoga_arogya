# Required: backend API URL
NEXT_PUBLIC_API_BASE_URL="http://localhost:5000/api"

# Required for contact form email sending (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-app-password"

# Required: email where you want to receive contact form messages
CONTACT_TO_EMAIL="your-email@gmail.com"

# Required: sender shown in outgoing mail (usually same as SMTP_USER)
CONTACT_FROM_EMAIL="your-email@gmail.com"
